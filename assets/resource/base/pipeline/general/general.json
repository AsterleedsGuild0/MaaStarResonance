    "同意申请与邀请入队": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": ["队伍/邀请入队的副本名称前面的图标.png"],
                "roi": [860, 163, 13, 14]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [1217, 148, 27, 25]
            }
        }
    },
    "挂机自动批复入队申请": {
        // 循环 24h 检测并同意入队申请
        "next": [
            "自动批复入队申请并继续循环",
            "[JumpBack]从省电模式唤醒"
        ],
        // 每轮识别最多消耗 8s = 8000ms, 入队批复等待最长 10s
        "rate_limit": 8000,
        // 1day = 24h * 60min * 60s * 1000ms = 86400000ms
        "timeout": 86400000
    },
    "自动批复入队申请并继续循环": {
        "recognition": {
            "type": "TemplateMatch",
